{
  "name": "@envolix/cli",
  "version": "0.0.1",
  "homepage": "https://github.com/jd-solanki/envolix#readme",
  "bugs": {
    "url": "https://github.com/jd-solanki/envolix/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jd-solanki/envolix.git",
    "directory": "packages/cli"
  },
  "bin": {
    "envolix": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {},
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "pack": "vp pack src/index.ts --clean --dts --format esm --sourcemap",
    "pkg:link": "pnpm add -g .",
    "pkg:unlink": "pnpm remove -g @envolix/cli"
  },
  "dependencies": {
    "@envolix/env-parser": "workspace:*",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  }
}
