{
  "name": "envolix",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/jd-solanki/envolix#readme",
  "bugs": {
    "url": "https://github.com/jd-solanki/envolix/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jd-solanki/envolix.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "check": "vp check",
    "cli:link": "pnpm --filter @envolix/cli run pkg:link",
    "cli:unlink": "pnpm --filter @envolix/cli run pkg:unlink",
    "ready": "vp run -r pack && vp check && vp test",
    "release:cli": "cd packages/cli && pnpm dlx bumpp patch --tag \"cli-v%s\" --commit \"chore(cli): release v%s\" --push",
    "release:env-parser": "cd packages/env-parser && pnpm dlx bumpp patch --tag \"env-parser-v%s\" --commit \"chore(env-parser): release v%s\" --push",
    "test": "vp test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3",
    "vite-plus": "^0.1.24"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "packageManager": "pnpm@11.6.0"
}
